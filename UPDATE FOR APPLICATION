<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>eGov Full System</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<!-- ================= LOGIN PAGE ================= -->
<div id="login-page" class="min-h-screen flex items-center justify-center bg-gray-100">
<div class="bg-white p-8 rounded shadow w-96">

<h2 id="login-title" class="text-2xl font-bold mb-2">Welcome Back</h2>
<p id="login-subtitle" class="text-gray-600 mb-6">Sign in to access your services</p>

<form>
<input type="email" placeholder="Email" required class="border p-2 w-full mb-3">
<input type="password" placeholder="Password" required class="border p-2 w-full mb-3">

<div id="reg-fields" class="hidden">
<input type="text" placeholder="Full Name" class="border p-2 w-full mb-3">
<input type="password" placeholder="Confirm Password" class="border p-2 w-full mb-3">
</div>

<div id="login-options" class="mb-3 text-sm text-gray-600">
Remember me
</div>

<button type="button" id="submit-btn"
class="bg-blue-600 text-white w-full py-2 rounded">
LOGIN
</button>
</form>

<p class="mt-4 text-sm text-center">
<span id="toggle-text">Don't have an account?</span>
<button id="toggle-btn" onclick="toggleAuthMode()" class="text-blue-600 font-semibold">
Create Account
</button>
</p>

</div>
</div>


<!-- ================= APPLICATION PAGE ================= -->
<div id="application-page" class="hidden p-10">

<div id="steps-indicator" class="flex mb-4"></div>

<div class="w-full bg-gray-200 h-2 rounded mb-6">
<div id="progress-bar" class="bg-blue-600 h-2 rounded" style="width:25%"></div>
</div>

<h2 id="step-title" class="text-xl font-bold"></h2>
<p id="step-description" class="mb-6 text-gray-600"></p>

<!-- STEP 1 -->
<div id="step-1">
<input type="text" placeholder="Full Name" class="border p-2 w-full mb-3">
<input type="text" placeholder="Address" class="border p-2 w-full mb-3">
</div>

<!-- STEP 2 -->
<div id="step-2" class="hidden">
<input type="file" onchange="handleFileUpload(event)" class="mb-3">
<div id="file-success-msg" class="hidden text-green-600">
Uploaded: <span id="uploaded-filename"></span>
</div>
</div>

<!-- STEP 3 -->
<div id="step-3" class="hidden">
<p>Documents: <span id="review-docs">None</span></p>
</div>

<!-- STEP 4 -->
<div id="step-4" class="hidden">
<p>Ready to submit your application.</p>
</div>

<div class="flex justify-between mt-6">
<button id="prev-btn" onclick="previousStep()" class="bg-gray-400 px-4 py-2 rounded">
← Previous
</button>
<button onclick="nextStep()" class="bg-blue-600 text-white px-4 py-2 rounded">
Next →
</button>
</div>

</div>


<!-- ================= PAYMENT PAGE ================= -->
<div id="payment-page" class="hidden p-10">

<h2 class="text-2xl font-bold mb-4">Payment</h2>

<p>Reference Number: <strong id="reference-number"></strong></p>

<div class="mt-6">

<label><input type="radio" id="method-card" checked onclick="switchPaymentMethod('card')"> Card</label>
<label class="ml-4"><input type="radio" id="method-banking" onclick="switchPaymentMethod('banking')"> Online Banking</label>
<label class="ml-4"><input type="radio" id="method-ewallet" onclick="switchPaymentMethod('ewallet')"> E-Wallet</label>

</div>

<!-- CARD PAYMENT -->
<div id="payment-card" class="mt-6">
<form id="card-form">
<input type="text" placeholder="Card Number" required class="border p-2 w-full mb-3">
<input type="text" placeholder="Expiry Date" required class="border p-2 w-full mb-3">
<input type="text" placeholder="CVV" required class="border p-2 w-full mb-3">
</form>
</div>

<!-- BANKING -->
<div id="payment-banking" class="hidden mt-6">
<p>Select your bank and proceed to online banking.</p>
</div>

<!-- EWALLET -->
<div id="payment-ewallet" class="hidden mt-6">
<p>Pay using GCash or PayMaya.</p>
</div>

<button onclick="processPayment()"
class="bg-green-600 text-white px-6 py-2 rounded mt-6">
Pay Now
</button>

</div>


<!-- ================= PAYMENT SUCCESS MODAL ================= -->
<div id="payment-success-modal"
class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center">

<div class="bg-white p-8 rounded shadow text-center">
<h3 class="text-xl font-bold mb-4 text-green-600">Payment Successful!</h3>
<p class="mb-6">Your application has been submitted.</p>

<button onclick="closePaymentSuccess()"
class="bg-blue-600 text-white px-4 py-2 rounded mr-3">
Go Home
</button>

<button onclick="trackApplication()"
class="bg-gray-600 text-white px-4 py-2 rounded">
Track Application
</button>

</div>
</div>

</body>
</html>
