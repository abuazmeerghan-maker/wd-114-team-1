<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>eGov Portal</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<!-- ================= LOGIN OPTIONS ================= -->
<div class="max-w-md mx-auto mt-10 bg-white p-8 rounded-lg shadow-lg">

    <!-- Remember Me / Forgot Password -->
    <div id="login-options" class="flex items-center justify-between mb-6 text-sm">
        <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" class="w-4 h-4">
            <span class="text-gray-600">Remember Me</span>
        </label>
        <a href="#" class="text-blue-600 hover:underline">Forgot Password?</a>
    </div>

    <!-- Submit Button -->
    <button type="submit"
        class="w-full bg-blue-900 hover:bg-blue-800 text-white font-semibold py-2 rounded-lg mb-4">
        LOGIN
    </button>

    <!-- Divider -->
    <div class="relative mb-4">
        <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-gray-500">OR</span>
        </div>
    </div>

    <!-- SSO Button -->
    <button type="button"
        class="w-full border-2 border-blue-900 text-blue-900 font-semibold py-2 rounded-lg hover:bg-blue-50 flex items-center justify-center gap-2">
        🛡️ Sign in with National ID (SSO)
    </button>

</div>


<!-- ================= SERVICES PAGE ================= -->
<section class="py-16 pt-20 bg-gray-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 space-y-8">

        <!-- Header -->
        <div>
            <h1 class="text-4xl font-bold text-gray-900">Available Services</h1>
            <p class="text-gray-600 mt-2">
                Browse and apply for government services
            </p>
        </div>

        <!-- Search -->
        <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex flex-col md:flex-row gap-4">
                <div class="flex-1">
                    <input type="text"
                        placeholder="Search services..."
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600">
                </div>
            </div>
        </div>

    </div>
</section>

</body>
</html>
