<!-- Payment Page -->
<section id="payment-page" class="hidden py-16 pt-20 bg-gray-50 min-h-screen">

    <div class="max-w-6xl mx-auto px-4 space-y-6">

        <!-- Header -->
        <div class="flex items-center gap-4">
            <button class="text-gray-600 hover:text-gray-900" onclick="togglePage('home')">
                ← Back
            </button>
            <div>
                <h1 class="text-3xl font-bold">Payment Details</h1>
                <p class="text-gray-600">Complete your payment to submit the application</p>
            </div>
        </div>

        <div class="grid lg:grid-cols-3 gap-6">

            <!-- LEFT SIDE -->
            <div class="lg:col-span-2 space-y-6">

                <!-- Payment Method -->
                <div class="bg-white rounded-lg shadow-md p-6">
                    <h2 class="text-xl font-bold mb-4">Select Payment Method</h2>
                    <div class="space-y-3">

                        <label class="flex items-center gap-4 border-2 border-gray-300 rounded-lg p-4 cursor-pointer"
                               onclick="switchPaymentMethod('card')">
                            <input type="radio" name="payment-method" value="card" checked>
                            <span class="text-2xl">💳</span>
                            <span class="font-semibold">Credit / Debit Card</span>
                        </label>

                        <label class="flex items-center gap-4 border-2 border-gray-300 rounded-lg p-4 cursor-pointer"
                               onclick="switchPaymentMethod('banking')">
                            <input type="radio" name="payment-method" value="banking">
                            <span class="text-2xl">🏦</span>
                            <span class="font-semibold">Online Banking</span>
                        </label>

                        <label class="flex items-center gap-4 border-2 border-gray-300 rounded-lg p-4 cursor-pointer"
                               onclick="switchPaymentMethod('ewallet')">
                            <input type="radio" name="payment-method" value="ewallet">
                            <span class="text-2xl">📱</span>
                            <span class="font-semibold">E-Wallet (GCash, PayMaya)</span>
                        </label>

                    </div>
                </div>

                <!-- CARD FORM -->
                <div id="payment-card" class="bg-white rounded-lg shadow-md p-6">
                    <h2 class="text-xl font-bold mb-4">Card Information</h2>

                    <form class="space-y-4">

                        <input type="text" placeholder="Cardholder Name"
                               class="w-full px-4 py-3 border rounded-lg" required>

                        <input type="text" placeholder="Card Number"
                               maxlength="19"
                               class="w-full px-4 py-3 border rounded-lg" required>

                        <div class="grid grid-cols-2 gap-4">
                            <input type="text" placeholder="MM/YY"
                                   maxlength="5"
                                   class="px-4 py-3 border rounded-lg" required>

                            <input type="password" placeholder="CVV"
                                   maxlength="3"
                                   class="px-4 py-3 border rounded-lg" required>
                        </div>

                        <button type="button"
                                onclick="processPayment()"
                                class="w-full bg-blue-900 text-white py-3 rounded-lg">
                            Pay ₱<span id="payment-total">520</span>
                        </button>

                    </form>
                </div>

                <!-- BANKING -->
                <div id="payment-banking" class="hidden bg-white rounded-lg shadow-md p-6 text-center">
                    <span class="text-5xl">🏦</span>
                    <h3 class="text-xl font-semibold mt-4">Online Banking</h3>
                    <button onclick="processPayment()"
                            class="mt-4 bg-blue-900 text-white py-2 px-8 rounded-lg">
                        Continue to Bank
                    </button>
                </div>

                <!-- E-WALLET -->
                <div id="payment-ewallet" class="hidden bg-white rounded-lg shadow-md p-6 text-center">
                    <span class="text-5xl">📱</span>
                    <h3 class="text-xl font-semibold mt-4">E-Wallet Payment</h3>

                    <div class="max-w-sm mx-auto space-y-3 mt-4">
                        <input type="tel" placeholder="Enter mobile number"
                               class="w-full px-4 py-3 border rounded-lg">

                        <button onclick="processPayment()"
                                class="w-full bg-blue-900 text-white py-3 rounded-lg">
                            Send Payment Request
                        </button>
                    </div>
                </div>

            </div>

            <!-- RIGHT SIDE SUMMARY -->
            <div>
                <div class="bg-white rounded-lg shadow-md p-6 sticky top-5">

                    <h2 class="text-xl font-bold mb-6">Payment Summary</h2>

                    <div class="space-y-3">
                        <div class="flex justify-between">
                            <span>Service:</span>
                            <span id="summary-service">Birth Certificate</span>
                        </div>

                        <div class="flex justify-between">
                            <span>Fee:</span>
                            <span id="summary-fee">₱500</span>
                        </div>

                        <div class="flex justify-between">
                            <span>Processing Fee:</span>
                            <span>₱20</span>
                        </div>

                        <hr>

                        <div class="flex justify-between font-bold text-lg">
                            <span>Total:</span>
                            <span>₱<span id="summary-total">520</span></span>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>


<!-- Payment Success Modal -->
<div id="payment-success-modal"
     class="hidden fixed inset-0 bg-black/50 flex items-center justify-center">

    <div class="bg-white rounded-lg max-w-md p-8 text-center">

        <div class="text-4xl mb-4">✅</div>

        <h2 class="text-2xl font-bold mb-4">Payment Successful!</h2>

        <div class="bg-gray-50 p-4 rounded-lg mb-4">
            <p class="text-sm text-gray-600">Reference Number</p>
            <p class="font-bold text-lg" id="reference-number">
                2026-BC-5234
            </p>
        </div>

        <button onclick="trackApplication()"
                class="w-full bg-blue-900 text-white py-3 rounded-lg mb-2">
            Track My Application
        </button>

        <button onclick="closePaymentSuccess()"
                class="w-full border border-gray-300 py-3 rounded-lg">
            Back to Dashboard
        </button>

    </div>
</div>
