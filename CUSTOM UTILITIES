<DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Custom Utilities Demo</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

      <style>
          /* Custom Utilities */
          * { transition: all 0.3s ease;}

            .hero-grandient {
                background: linear-gradient (135deg, #667eea 0%, #764ba2 100%);
                        padding: 60px 20px;
                        text-align: center;
                        color:white;
}
.fade-in {
    animation: fadeIn 0.5s ease-in;
}
@keyframes fadeIn {
    from { opacity: 0; transofrm:translateY(20px);}
    to { opacity:1; transform: translateY (0); }
}

.btn-primary {
    background-color: #256eb;
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    border:none;
    cursor:pointer;
}
 
.btn-primary:hover {
background-color: #1d4ed8;
}

.status-badge {
padding: 0.25rem 0.75rem;
border-radius: 9999px;
font-size: 0.75rem;
display: inline-block;
margin: 5px;
}

.status-pending {
background-color: #fef3c7;
color: #166534;

}

.status approved {
background-color: #dcfce7;
color: # 166534;

}

.status-processing {
  background-color: #dbeafe;
  color: #11e40af;
}
.content {
  padding: 40px;
  text-align: center;
}
</style>
</head>
<body>

<!--  Hero Section -->
<div class ="hero-gradient fade-in">
<h1> Welcome to the Portal</h1>
<p> This section uses hero-gradient and fade-in animation.</p>
<button class= "btn-primary"> Get Started</button>
</div>

<!-- Status Section-->
<div class="content fade-in">
  <h2> Application Status </h2>
  <span class="status-badge status-pending">Pending</span>
  <span class="status-badge ststaus-processing">Processing</span>
    <span class="status-badge status-approved">Approved</span>
</div>
</body>
</html>
