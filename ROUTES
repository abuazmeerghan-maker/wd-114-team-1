<DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>eGov- Citizen Services Portal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- Tailwind CSS CDN-->
<script src="https://cdn.tailwindcss.com"></script>

<style>
:root {
  --font-size:16px;
  --background: #fffff;
  --foreground: #1f29437;
  --primary: #030213;
  --secondary: #f3f4f6;
  --accent: #e9ebef;
  --destructive: #d4183d;
  --radius: 0.625rem;
}

body {
font-size: var (--font-size);
background-color: var (--background);
color: var (--foreground);
font-family: Arial, sans-serif;
}

.card {
  background-color: var (--secondary);
border-radius: var (--radius);
}

.btn-primary {
  background-color: var (--primary);
  color:white;
  padding: 10px 20px;
  border-radius: var (--radius);
}

.btn-primary:hover {
  opacity: 0.8;
)

  </style>
</head>

<body class_"min-h-screen flex flex-col">


<!--Header -->
<header class="bg-black text-white p-4">
      <h1 class= "text-2x1 font-bold">eGov - Citizen Services Portal</h1>
</header>

<!-- Main Content-->
<main class="flex-1 p-8">
    <div class="card p-6 shadow-md">
        <h2 class= "text-x1 font-semibold mb-4"> Welcome to the Portal</h2>
                  <p class="mb-4">
                    Access government services online including applications, payments,  and tracking.
</p>
    <button class="btn-primary"> Get Started</button>
</div>

</main>
<!--Footer-->
<footer class="bg-gray-200 text-center p-4">
      c 2026 eGov Portal. All rights reserved.
</footer>

</body>
</html>
