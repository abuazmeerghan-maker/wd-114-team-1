<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>eGov Services</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        .btn-primary {
            background-color: #1e3a8a;
            color: white;
            font-weight: 600;
            padding: 10px;
            border-radius: 8px;
            transition: 0.3s;
        }

        .btn-primary:hover {
            background-color: #1e40af;
        }
    </style>
</head>

<body class="bg-gray-100">

<!-- ================= SERVICES SECTION ================= -->
<section class="py-16 bg-gray-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4">

        <!-- Filter -->
        <div class="mb-6">
            <select class="px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-600">
                <option>All Prices</option>
                <option>Free</option>
                <option>Paid</option>
            </select>
        </div>

        <!-- Services Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            <!-- Birth Certificate -->
            <div class="bg-white rounded-xl shadow-md p-6 hover:shadow-xl transition">
                <div class="text-3xl mb-4">📄</div>
                <h3 class="text-xl font-bold mb-2">Birth Certificate</h3>
                <p class="text-gray-600 text-sm mb-4">
                    Request an official birth certificate online.
                </p>
                <span class="text-green-600 font-bold block mb-4">FREE</span>
                <button class="w-full btn-primary">Apply Now →</button>
            </div>

            <!-- Driver's License -->
            <div class="bg-white rounded-xl shadow-md p-6 hover:shadow-xl transition">
                <div class="text-3xl mb-4">🚗</div>
                <h3 class="text-xl font-bold mb-2">Driver's License</h3>
                <p class="text-gray-600 text-sm mb-4">
                    Apply or renew your driver's license.
                </p>
                <span class="font-bold block mb-4">₱500</span>
                <button class="w-full btn-primary">Apply Now →</button>
            </div>

            <!-- Business Registration -->
            <div class="bg-white rounded-xl shadow-md p-6 hover:shadow-xl transition">
                <div class="text-3xl mb-4">🏢</div>
                <h3 class="text-xl font-bold mb-2">Business Registration</h3>
                <p class="text-gray-600 text-sm mb-4">
                    Register your new business entity.
                </p>
                <span class="font-bold block mb-4">₱1,200</span>
                <button class="w-full btn-primary">Apply Now →</button>
            </div>

        </div>
    </div>
</section>


<!-- ================= APPLICATION FORM ================= -->
<section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">

        <h1 class="text-3xl font-bold mb-6">Service Application Form</h1>

        <div class="bg-gray-50 p-6 rounded-lg shadow-md">

            <h2 class="text-xl font-bold mb-4">Personal Information</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <input type="text" placeholder="First Name"
                    class="px-4 py-3 border rounded-lg w-full">

                <input type="text" placeholder="Last Name"
                    class="px-4 py-3 border rounded-lg w-full">
            </div>

            <input type="date"
                class="px-4 py-3 border rounded-lg w-full mb-4">

            <textarea rows="3" placeholder="Complete Address"
                class="px-4 py-3 border rounded-lg w-full mb-4"></textarea>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <input type="tel" placeholder="Contact Number"
                    class="px-4 py-3 border rounded-lg w-full">

                <input type="email" placeholder="Email Address"
                    class="px-4 py-3 border rounded-lg w-full">
            </div>

            <button class="btn-primary w-full">Submit Application</button>

        </div>

    </div>
</section>

</body>
</html>
