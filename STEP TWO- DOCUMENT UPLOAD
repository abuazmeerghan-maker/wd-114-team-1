<!-- Step 2: Document Upload -->
<div id="step-2" class="hidden space-y-4">

    <!-- Upload Box -->
    <div class="border-2 border-dashed border-gray-300 rounded-lg p-8">
        <div class="text-center space-y-4">
            <span class="text-4xl block">📄</span>

            <div>
                <h3 class="font-semibold text-gray-900">Upload Required Documents</h3>
                <p class="text-sm text-gray-600 mt-1">
                    Drag and drop files here, or click to browse
                </p>
                <p class="text-xs text-gray-500 mt-2">
                    Accepted formats: PDF, JPG, PNG (Max 5MB)
                </p>
            </div>

            <!-- File Input -->
            <input 
                type="file" 
                id="file-upload" 
                accept=".pdf,.jpg,.jpeg,.png" 
                class="w-full max-w-xs mx-auto"
                onchange="handleFileUpload(event)"
            >
        </div>
    </div>

    <!-- Success Message -->
    <div id="file-success-msg" class="hidden p-4 bg-green-50 border border-green-200 rounded-lg">
        <p class="text-sm text-green-800">
            ✓ File uploaded: 
            <span class="font-semibold" id="uploaded-filename"></span>
        </p>
    </div>

    <!-- Required Documents Info -->
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
        <h4 class="font-semibold text-blue-900 mb-2">
            Required Documents:
        </h4>
        <ul class="text-sm text-blue-800 space-y-1">
            <li>• Valid Government ID</li>
            <li>• Proof of Address</li>
            <li>• Supporting documents (if applicable)</li>
        </ul>
    </div>

</div>
